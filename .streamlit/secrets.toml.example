# Streamlit Cloud: App → Settings → Secrets — paste both keys below (no GitHub upload needed).
# Local: copy to .streamlit/secrets.toml to test URLs. Never commit real URLs or base64. 
#
# On Streamlit Cloud, both keys are required; the app never reads Excel from the repo there.

DATA_XLSX = "https://example.com/path/data.xlsx"
SALES_VAR_XLSX = "https://example.com/path/salesVariability.xlsx"
